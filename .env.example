# Firebase Configuration (Client-side) - Required for Auth
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (Server-side) - Required for API routes
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"

# AI Model Providers - Add your API keys here (or set per-user in Settings)
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Web Search (Tavily)
TAVILY_API_KEY=your_tavily_api_key

# Default Model (optional, defaults to gemini-1.5-flash)
# DEFAULT_MODEL=gemini-1.5-flash

# Supabase (Optional - only if using Supabase for storage)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Available Models
# ============================================
# 
# FREE / DEVELOPER-TIER SHORTLIST:
#   gemini-2.5-flash-lite, gemini-2.5-flash, llama-3.1-8b-instant,
#   ministral-3b-latest, openrouter-free, qwen-2.5-vl-7b-free, deepseek-r1-free
#
# GOOGLE (requires GOOGLE_API_KEY):
#   gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro,
#   gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
#
# OPENAI (requires OPENAI_API_KEY):
#   gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo
#
# GROQ (requires GROQ_API_KEY):
#   llama-3.1-8b-instant, llama-3.1-70b, groq-gpt-oss-20b,
#   groq-gpt-oss-120b, groq-qwen3-32b, groq-compound-mini
#
# MISTRAL (requires MISTRAL_API_KEY):
#   ministral-3b-latest, ministral-8b-latest, ministral-14b-latest,
#   mistral-small-latest, magistral-small-latest
#
# OPENROUTER (requires OPENROUTER_API_KEY):
#   openrouter-free, qwen-2.5-vl-7b-free, deepseek-r1-free,
#   deepseek-chat-v3-free, llama-3.1-8b-openrouter-free, qwen3-coder-free
#   claude-3-opus, claude-3.5-sonnet, claude-3-haiku
#   mistral-large, mistral-small, command-r, command-r-plus
#   qwen-2.5-72b, qwen-2.5-32b, qwen-2.5-14b, qwen-2.5-7b
#   deepseek-chat, deepseek-coder, llama-3.3-70b, llama-3.3-8b
#   phi-4-mini, phi-3.5-mini, gemma-2-27b, gemma-2-9b
#   nemotron-70b, marco-o1, minimax-m2
# ============================================
